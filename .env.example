# YouTube MP3 Downloader API Configuration
#
# Wajib: Daftar di https://rapidapi.com/ untuk mendapatkan API key gratis
# Cari: "YouTube to MP3" atau "YouTube MP3 Download"

# RapidAPI Key (dapatkan dari dashboard RapidAPI setelah registrasi)
VIDEO_DOWNLOAD_API_KEY=def75767edmshd9e7a024aa47dcfp1de5acjsn2f5d1019c899

# Host API (default: youtube-to-mp315.p.rapidapi.com)
VIDEO_DOWNLOAD_API_HOST=youtube-to-mp315.p.rapidapi.com

# Catatan:
# - Tier gratis RapidAPI biasanya memberikan 100-500 request/hari
# - Untuk production, pertimbangkan upgrade ke plan berbayar
# - API key tidak perlu di-commit ke repository (gunakan Environment Variables di Vercel)
